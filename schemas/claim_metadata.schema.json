{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClaimMetadata",
  "type": "object",
  "required": [
    "claim_id",
    "speaker",
    "statement_text",
    "statement_time_utc",
    "ingest_time_utc",
    "source_url",
    "source_hash",
    "state"
  ],
  "properties": {
    "claim_id": {
      "type": "string"
    },
    "speaker": {
      "type": "string"
    },
    "statement_text": {
      "type": "string"
    },
    "statement_time_utc": {
      "type": "string",
      "format": "date-time"
    },
    "ingest_time_utc": {
      "type": "string",
      "format": "date-time"
    },
    "source_url": {
      "type": "string"
    },
    "source_hash": {
      "type": "string"
    },
    "evidence_links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "state": {
      "type": "string",
      "enum": [
        "STABLE",
        "UNSTABLE",
        "MAPPING",
        "BACKFILLED",
        "RESIDUAL"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "jurisdiction": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    }
  }
}